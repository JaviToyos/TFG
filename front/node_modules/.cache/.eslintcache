ias] = useState([]);\n    const [goCardless, setGoCardless] = useState([]);\n\n    useEffect(() => {\n        if (!esNuevo) {\n            proveedorService.buscarPorId(params.idProveedor).then(res => setProveedor(res.data));\n        }\n        cuentaBancariaService.buscarTodas().then(res => setCuentasBancarias(res.data));\n        goCardlessService.buscarTodas().then(res => setGoCardless(res.data));\n    },[]); // Carga después del primer renderizado\n\n    return (\n        <div>\n            {/* Contenido de Proveedor */}\n        </div>\n    );\n}","C:\\xampp\\htdocs\\Gestor-Cuentas - copia\\front\\src\\components\\goCardless\\goCardlessDetalle.js",["358","359","360","361","362","363","364","365","366","367","368","369","370","371"],[],"C:\\xampp\\htdocs\\Gestor-Cuentas - copia\\front\\src\\components\\proveedor\\proveedorListado.js",["372","373","374","375","376","377","378","379","380","381","382","383","384","385","386","387","388","389","390","391"],[],"C:\\xampp\\htdocs\\Gestor-Cuentas - copia\\front\\src\\components\\persona\\personaDetalle.js",["392","393","394","395","396","397","398","399","400","401","402","403","404","405"],[],"C:\\xampp\\htdocs\\Gestor-Cuentas - copia\\front\\src\\components\\usuario\\usuarioListado.js",["406","407","408","409","410","411","412","413","414","415","416","417","418","419","420","421","422","423","424"],[],"C:\\xampp\\htdocs\\Gestor-Cuentas - copia\\front\\src\\components\\persona\\personaListado.js",["425","426","427","428","429","430","431","432","433","434","435","436","437","438","439","440","441","442","443","444"],[],"C:\\xampp\\htdocs\\Gestor-Cuentas - copia\\front\\src\\components\\usuario\\usuarioDetalle.js",["445","446","447","448","449","450","451","452","453","454","455","456","457"],[],"C:\\xampp\\htdocs\\Gestor-Cuentas - copia\\front\\src\\services\\goCardlessService.js",["458"],[],"import api from \"./gestorCuentasAPI\";\n\nclass GoCardlessService {\n  buscarTodos() {\n    return api.get(\"/goCardless\");